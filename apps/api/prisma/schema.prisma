generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SchoolStatus {
  ACTIVE
  SUSPENDED

  @@map("school_status")
}

enum UserStatus {
  ACTIVE
  SUSPENDED

  @@map("user_status")
}

/// Global — tenant registry. Never scoped by RLS/tenant middleware.
model School {
  id            String       @id @default(uuid())
  name          String
  slug          String       @unique
  subdomain     String       @unique
  logoUrl       String?      @map("logo_url")
  timezone      String       @default("UTC")
  localeDefault String       @default("en") @map("locale_default")
  status        SchoolStatus @default(ACTIVE)
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  users         User[]
  roles         Role[]
  academicYears AcademicYear[]
  gradeLevels   GradeLevel[]
  classes       Class[]
  subjects      Subject[]
  classSubjects ClassSubject[]
  teachers         Teacher[]
  students         Student[]
  parents          Parent[]
  studentGuardians StudentGuardian[]
  timetableSlots   TimetableSlot[]

  @@map("schools")
}

/// Tenant-scoped. Single auth identity for every human in a school.
model User {
  id           String     @id @default(uuid())
  schoolId     String     @map("school_id")
  school       School     @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  email        String?
  civilId      String?    @map("civil_id")
  passwordHash String     @map("password_hash")
  phone        String?
  status       UserStatus @default(ACTIVE)
  locale       String     @default("en")
  lastLoginAt  DateTime?  @map("last_login_at")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  userRoles     UserRole[]
  refreshTokens RefreshToken[]
  teacher       Teacher?
  student       Student?
  parent        Parent?

  @@unique([schoolId, email])
  @@unique([schoolId, civilId])
  @@index([schoolId])
  @@map("users")
}

/// Tenant-scoped. Rotated on every refresh; `familyId` groups a login session's
/// chain so reuse of an already-rotated token revokes the whole chain at once.
model RefreshToken {
  id         String    @id @default(uuid())
  schoolId   String    @map("school_id")
  userId     String    @map("user_id")
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash  String    @unique @map("token_hash")
  familyId   String    @map("family_id")
  deviceInfo String?   @map("device_info")
  expiresAt  DateTime  @map("expires_at")
  revokedAt  DateTime? @map("revoked_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  @@index([schoolId])
  @@index([userId])
  @@index([familyId])
  @@map("refresh_tokens")
}

/// Tenant-scoped, but schoolId is nullable: null = platform default role, cloneable per school.
model Role {
  id              String   @id @default(uuid())
  schoolId        String?  @map("school_id")
  school          School?  @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  name            String
  isSystemDefault Boolean  @default(false) @map("is_system_default")
  createdAt       DateTime @default(now()) @map("created_at")

  rolePermissions RolePermission[]
  userRoles       UserRole[]

  @@index([schoolId])
  @@map("roles")
}

/// Global — permission catalog is the same across every tenant.
model Permission {
  id          String  @id @default(uuid())
  key         String  @unique
  module      String
  description String?

  rolePermissions RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       String @map("role_id")
  permissionId String @map("permission_id")

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model UserRole {
  userId String @map("user_id")
  roleId String @map("role_id")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("user_roles")
}

/// Global — platform operators, deliberately outside RLS/tenant scope.
/// Never joined into the tenant-scoping Prisma extension.
model SuperAdmin {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  name         String
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("super_admins")
}

model AcademicYear {
  id        String   @id @default(uuid())
  schoolId  String   @map("school_id")
  school    School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  name      String
  startDate DateTime @map("start_date")
  endDate   DateTime @map("end_date")
  isCurrent Boolean  @default(false) @map("is_current")
  createdAt DateTime @default(now()) @map("created_at")

  classes Class[]

  @@index([schoolId])
  @@map("academic_years")
}

model GradeLevel {
  id       String @id @default(uuid())
  schoolId String @map("school_id")
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  name     String
  order    Int

  classes Class[]

  @@index([schoolId])
  @@map("grade_levels")
}

model Class {
  id                String       @id @default(uuid())
  schoolId          String       @map("school_id")
  school            School       @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  gradeLevelId      String       @map("grade_level_id")
  gradeLevel        GradeLevel   @relation(fields: [gradeLevelId], references: [id], onDelete: Cascade)
  academicYearId    String       @map("academic_year_id")
  academicYear      AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  name              String
  homeroomTeacherId String?      @map("homeroom_teacher_id")
  homeroomTeacher   Teacher?     @relation(fields: [homeroomTeacherId], references: [id], onDelete: SetNull)
  capacity          Int?
  createdAt         DateTime     @default(now()) @map("created_at")

  students      Student[]
  classSubjects ClassSubject[]

  @@index([schoolId])
  @@index([academicYearId])
  @@map("classes")
}

model Subject {
  id       String @id @default(uuid())
  schoolId String @map("school_id")
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  name     String
  code     String

  classSubjects ClassSubject[]

  @@unique([schoolId, code])
  @@index([schoolId])
  @@map("subjects")
}

model ClassSubject {
  id        String   @id @default(uuid())
  schoolId  String   @map("school_id")
  school    School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  classId   String   @map("class_id")
  class     Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  subjectId String   @map("subject_id")
  subject   Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  teacherId String?  @map("teacher_id")
  teacher   Teacher? @relation(fields: [teacherId], references: [id], onDelete: SetNull)

  timetableSlots TimetableSlot[]

  @@unique([classId, subjectId])
  @@index([schoolId])
  @@map("class_subjects")
}

/// Tenant-scoped. `startTime`/`endTime` as zero-padded "HH:mm" so lexicographic
/// string comparison in overlap queries is also correct time comparison —
/// avoids timezone handling for a value that's always local wall-clock time.
model TimetableSlot {
  id             String       @id @default(uuid())
  schoolId       String       @map("school_id")
  school         School       @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  classSubjectId String       @map("class_subject_id")
  classSubject   ClassSubject @relation(fields: [classSubjectId], references: [id], onDelete: Cascade)
  dayOfWeek      Int          @map("day_of_week")
  startTime      String       @map("start_time")
  endTime        String       @map("end_time")
  room           String?
  createdAt      DateTime     @default(now()) @map("created_at")

  @@index([schoolId])
  @@index([classSubjectId])
  @@index([schoolId, dayOfWeek])
  @@map("timetable_slots")
}

model Teacher {
  id             String   @id @default(uuid())
  schoolId       String   @map("school_id")
  school         School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  userId         String   @unique @map("user_id")
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  employeeNumber String   @map("employee_number")
  hireDate       DateTime @map("hire_date")
  employmentType String   @default("full_time") @map("employment_type")
  department     String?
  createdAt      DateTime @default(now()) @map("created_at")

  homeroomClasses Class[]
  classSubjects   ClassSubject[]

  @@unique([schoolId, employeeNumber])
  @@index([schoolId])
  @@map("teachers")
}

enum StudentStatus {
  ACTIVE
  GRADUATED
  TRANSFERRED
  WITHDRAWN

  @@map("student_status")
}

model Student {
  id              String        @id @default(uuid())
  schoolId        String        @map("school_id")
  school          School        @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  userId          String        @unique @map("user_id")
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  classId         String?       @map("class_id")
  class           Class?        @relation(fields: [classId], references: [id], onDelete: SetNull)
  admissionNumber String        @map("admission_number")
  dateOfBirth     DateTime?     @map("date_of_birth")
  gender          String?
  enrollmentDate  DateTime      @default(now()) @map("enrollment_date")
  status          StudentStatus @default(ACTIVE)
  createdAt       DateTime      @default(now()) @map("created_at")

  guardians StudentGuardian[]

  @@unique([schoolId, admissionNumber])
  @@index([schoolId])
  @@index([classId])
  @@map("students")
}

model Parent {
  id                  String   @id @default(uuid())
  schoolId            String   @map("school_id")
  school              School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  userId              String   @unique @map("user_id")
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  occupation          String?
  relationshipDefault String?  @map("relationship_default")
  createdAt           DateTime @default(now()) @map("created_at")

  students StudentGuardian[]

  @@index([schoolId])
  @@map("parents")
}

model StudentGuardian {
  id               String  @id @default(uuid())
  schoolId         String  @map("school_id")
  school           School  @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  studentId        String  @map("student_id")
  student          Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  parentId         String  @map("parent_id")
  parent           Parent  @relation(fields: [parentId], references: [id], onDelete: Cascade)
  relationship     String
  isPrimaryContact Boolean @default(false) @map("is_primary_contact")

  @@unique([studentId, parentId])
  @@index([schoolId])
  @@map("student_guardians")
}
